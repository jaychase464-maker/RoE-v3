MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: fd910218dd293fc4f8d3f8ca18edf4a1, type: 3}
  m_Name: M5_TrainingOperation
  m_EditorClassIdentifier: RulesOfEntry.Runtime::RulesOfEntry.Missions.MissionDefinition
  missionId: m6_pressure_point
  displayName: 'Operation: Pressure Point'
  briefing: Respond to an armed-subject incident at a municipal pumping annex. Establish
    control, protect the reported employee, clear the pump hall, resolve the subject
    lawfully, and document every use of force.
  objectives:
  - objectiveId: secure_primary_suspect
    displayName: Secure the primary suspect
    briefing: Take the identified armed subject into lawful custody.
    type: 0
    targetActorId: m3_suspect_01
    targetRoomId: 
    isRequired: 1
    failureDeduction: 30
  - objectiveId: protect_facility_employee
    displayName: Protect the facility employee
    briefing: Locate and protect the reported municipal employee.
    type: 1
    targetActorId: m3_civilian_01
    targetRoomId: 
    isRequired: 1
    failureDeduction: 25
  - objectiveId: verify_pump_hall_clear
    displayName: Verify the pump hall clear
    briefing: Conduct a deliberate search and confirm that no active threat remains
      in the primary process space.
    type: 2
    targetActorId: 
    targetRoomId: m7a_pump_hall
    isRequired: 1
    failureDeduction: 25
  - objectiveId: preserve_response_team
    displayName: Preserve the response team
    briefing: No assigned officer may become incapacitated or die.
    type: 3
    targetActorId: 
    targetRoomId: 
    isRequired: 1
    failureDeduction: 20
  targetCompletionSeconds: 600
  maximumScoredCompletionSeconds: 1200
